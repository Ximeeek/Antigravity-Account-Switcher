{
  "name": "antigravity-account-switcher",
  "displayName": "Antigravity Account Switcher",
  "description": "Manual account selection for the local Antigravity Account Switcher desktop app.",
  "version": "0.1.0",
  "publisher": "local",
  "license": "UNLICENSED",
  "engines": {
    "vscode": "^1.85.0"
  },
  "extensionKind": [
    "ui"
  ],
  "categories": [
    "Other"
  ],
  "keywords": [
    "antigravity",
    "account",
    "profile"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:antigravityAccountSwitcher.activateProfile",
    "onCommand:antigravityAccountSwitcher.refresh",
    "onCommand:antigravityAccountSwitcher.openSwitcher"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run package",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "compile": "tsc -p ./",
    "check": "tsc -p ./ --noEmit",
    "package": "npm run clean && npm run compile",
    "watch": "tsc -p ./ --watch"
  },
  "contributes": {
    "commands": [
      {
        "command": "antigravityAccountSwitcher.activateProfile",
        "title": "Antigravity Switcher: Aktywuj profil"
      },
      {
        "command": "antigravityAccountSwitcher.refresh",
        "title": "Antigravity Switcher: Odśwież stan"
      },
      {
        "command": "antigravityAccountSwitcher.openSwitcher",
        "title": "Antigravity Switcher: Otwórz aplikację"
      }
    ],
    "configuration": {
      "title": "Antigravity Account Switcher",
      "properties": {
        "antigravityAccountSwitcher.port": {
          "type": "number",
          "default": 48731,
          "minimum": 1,
          "maximum": 65535,
          "scope": "machine",
          "description": "Port lokalnego API aplikacji desktopowej. Host jest zawsze ustawiony na 127.0.0.1."
        },
        "antigravityAccountSwitcher.apiSecret": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "markdownDescription": "Sekret Bearer lokalnego API. Wartość musi odpowiadać konfiguracji aplikacji desktopowej. Nie zapisuj tutaj tokenu Google OAuth."
        },
        "antigravityAccountSwitcher.requestTimeoutMs": {
          "type": "number",
          "default": 5000,
          "minimum": 500,
          "maximum": 30000,
          "scope": "machine",
          "description": "Limit czasu pojedynczego żądania do lokalnej aplikacji, w milisekundach."
        }
      }
    }
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.8.3"
  }
}
